# Copiar a openclaw/.env y rellenar valores reales.
# Ver también openclaw/.env.example (submódulo upstream).

COMPOSE_FILE=docker-compose.yml:../docker-overrides/docker-compose.finanzas-mounts.yml
OPENCLAW_IMAGE=openclaw-with-ssh:local
OPENCLAW_PROJECT_DIR=/home/mauro/Dev/openclaw-mauro
OPENCLAW_CONFIG_DIR=/home/mauro/Dev/openclaw-mauro/data/config
OPENCLAW_WORKSPACE_DIR=/home/mauro/Dev/openclaw-mauro/data/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=/home/mauro/Dev/openclaw-mauro/data/auth-profile-secrets
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=auto
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=America/Santiago
OPENCLAW_SKIP_ONBOARDING=1
OTEL_SERVICE_NAME=openclaw-mauro

# --- Secretos (rellenar) ---
# OPENCLAW_GATEWAY_TOKEN=
TELEGRAM_BOT_TOKEN=
LITELLM_MASTER_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_KEY=ollama-local

OPENCLAW_REPOS_DIR=/home/mauro/Dev/openclaw-mauro/repos
