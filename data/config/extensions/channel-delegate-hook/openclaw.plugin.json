{
  "id": "channel-delegate-hook",
  "name": "Channel Delegate Hook",
  "description": "Runs channel_delegate.py before the LLM on WhatsApp/Telegram (agent main) and returns whatsapp_reply when handled.",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentId": {
        "type": "string",
        "default": "main"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 300000,
        "default": 120000
      }
    }
  }
}
